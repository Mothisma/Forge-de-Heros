{% extends 'base.html.twig' %}

{% block title %}CharacterClass index{% endblock %}

{% block body %}
    <h1>Liste des classes</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Nom</th>
                <th>Description</th>
                <th>Dé de Vie</th>
                <th>Compétences</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for character_class in character_classes %}
            <tr>
                <td>{{ character_class.name }}</td>
                <td>{{ character_class.description }}</td>
                <td>{{ character_class.healthDice }}</td>
                <td>
                    {% for skill in character_class.skills %}
                    <a href="{{ path('app_skill_show', {'id': skill.id}) }}">
                        {{ skill.name }}
                        </a>{% if not loop.last %}, {% endif %}
                    {% else %}
                        Aucune compétence
                    {% endfor %}
                </td>
                <td>
                    <a href="{{ path('app_character_class_show', {'id': character_class.id}) }}">Afficher</a>
                    <a href="{{ path('app_character_class_edit', {'id': character_class.id}) }}">Modifier</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="5">Aucune classe enregistrée</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_character_class_new') }}">Nouvelle classe</a>
{% endblock %}
