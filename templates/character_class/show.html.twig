{% extends 'base.html.twig' %}

{% block title %}Classes{% endblock %}

{% block body %}
    <h1>Classes</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Nom</th>
                <td>{{ character_class.name }}</td>
            </tr>
            <tr>
                <th>Description</th>
                <td>{{ character_class.description }}</td>
            </tr>
            <tr>
                <th>Dé de Vie</th>
                <td>{{ character_class.healthDice }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_character_class_index') }}">Retour</a>

    <a href="{{ path('app_character_class_edit', {'id': character_class.id}) }}">Modifier</a>

    {{ include('character_class/_delete_form.html.twig') }}
{% endblock %}
