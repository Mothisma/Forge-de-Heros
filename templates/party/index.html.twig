{% extends 'base.html.twig' %}

{% block title %}Liste des groupes{% endblock %}

{% block body %}
    <h1>Groupes</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Nom</th>
                <th>Description</th>
                <th>Taille max</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        <a href="{{ path('app_party_index', {status: 'all'}) }}">Tous</a>
        <a href="{{ path('app_party_index', {status: 'available'}) }}">Places disponibles</a>
        <a href="{{ path('app_party_index', {status: 'full'}) }}">Groupes complets</a>
        {% for party in parties %}
            <tr>
                <td>{{ party.name }}</td>
                <td>{{ party.description }}</td>
                <td>{{ party.maxSize }}</td>
                <td>
                    <a href="{{ path('app_party_show', {'id': party.id}) }}">Voir</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="5">Aucun groupe trouvé</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_party_new') }}">Créer un nouveau groupe</a>
{% endblock %}
