{% extends 'base.html.twig' %}

{% block title %}Liste des personnages{% endblock %}

{% block body %}
    <h1>Liste des personnages</h1>

    <form method="get" action="{{ path('app_character_index') }}" class="mb-3">

        <label for="name">Nom :</label>
        <input type="text" name="name" id="name" value="{{ searchedName }}">

        <label for="race">Race :</label>
        <select name="race" id="race">
            <option value="">-- Toutes --</option>
            <option value="1" {{ selectedRace == 1 ? 'selected' }}>Humain</option>
            <option value="2" {{ selectedRace == 2 ? 'selected' }}>Elfe</option>
            <option value="3" {{ selectedRace == 3 ? 'selected' }}>Nain</option>
            <option value="4" {{ selectedRace == 4 ? 'selected' }}>Halfelin</option>
            <option value="5" {{ selectedRace == 5 ? 'selected' }}>Demi-Orc</option>
            <option value="6" {{ selectedRace == 6 ? 'selected' }}>Gnome</option>
            <option value="7" {{ selectedRace == 7 ? 'selected' }}>Tieffelin</option>
            <option value="8" {{ selectedRace == 8 ? 'selected' }}>Demi-Elfe</option>
        </select>

        <label for="class">Classe :</label>
        <select name="class" id="class">
            <option value="">-- Toutes --</option>
            <option value="1" {{ selectedClass == 1 ? 'selected' }}>Barbare</option>
            <option value="2" {{ selectedClass == 2 ? 'selected' }}>Barde</option>
            <option value="3" {{ selectedClass == 3 ? 'selected' }}>Clerc</option>
            <option value="4" {{ selectedClass == 4 ? 'selected' }}>Druide</option>
            <option value="5" {{ selectedClass == 5 ? 'selected' }}>Guerrier</option>
            <option value="6" {{ selectedClass == 6 ? 'selected' }}>Mage</option>
            <option value="7" {{ selectedClass == 7 ? 'selected' }}>Paladin</option>
            <option value="8" {{ selectedClass == 8 ? 'selected' }}>Ranger</option>
            <option value="9" {{ selectedClass == 9 ? 'selected' }}>Sorcier</option>
            <option value="10" {{ selectedClass == 10 ? 'selected' }}>Voleur</option>
        </select>

        <button type="submit">Filtrer</button>
    </form>

    <table class="table">
        <thead>
            <tr>
                <th>Nom</th>
                <th>Niveau</th>
                <th>Force</th>
                <th>Dextérité</th>
                <th>Constitution</th>
                <th>Intelligence</th>
                <th>Sagesse</th>
                <th>Charisme</th>
                <th>Point de vie</th>
                <th>Image</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
        {% for character in characters %}
            <tr>
                <td>{{ character.name }}</td>
                <td>{{ character.level }}</td>
                <td>{{ character.strength }}</td>
                <td>{{ character.dexterity }}</td>
                <td>{{ character.constitution }}</td>
                <td>{{ character.inteligence }}</td>
                <td>{{ character.wisdom }}</td>
                <td>{{ character.charisma }}</td>
                <td>{{ character.healthPoints }}</td>
                <td>{{ character.image }}</td>
                <td>
                    <a href="{{ path('app_character_show', {'id': character.id}) }}">Voir</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="12">Aucun personnage enregistré</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_character_new') }}">Nouveau personnage</a>
{% endblock %}
