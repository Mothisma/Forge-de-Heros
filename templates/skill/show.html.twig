{% extends 'base.html.twig' %}

{% block title %}Compétence{% endblock %}

{% block body %}
    <h1>Compétence</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>ID</th>
                <td>{{ skill.id }}</td>
            </tr>
            <tr>
                <th>Nom</th>
                <td>{{ skill.name }}</td>
            </tr>
            <tr>
                <th>Capacités</th>
                <td>{{ skill.ability }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_skill_index') }}">Retour à la liste</a>

    <a href="{{ path('app_skill_edit', {'id': skill.id}) }}">Modifier</a>

    {{ include('skill/_delete_form.html.twig') }}
{% endblock %}
